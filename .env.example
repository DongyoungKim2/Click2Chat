# 필수: ChatGPT에서 사용할 프로젝트 URL
CLICK2CHAT_PROJECT_URL=https://chatgpt.com/g/g-p-example/project

# 필수: 시스템 설정에 표시되는 장치 이름과 Bluetooth/HID 제품명 일부
CLICK2CHAT_INPUT_DEVICE_NAME=External Microphone
CLICK2CHAT_OUTPUT_DEVICE_NAME=External Speaker
CLICK2CHAT_BUTTON_NAME_HINTS=Snapshot,Headset

# 선택: 비워 두면 자동 첫 인사를 보내지 않습니다.
CLICK2CHAT_OPENING_PROMPT="안녕! 무엇이 궁금해?"

# 선택: 일반적인 설치에서는 아래 기본값을 변경하지 않아도 됩니다.
CLICK2CHAT_CHROME_PATH=/Applications/Google Chrome.app
CLICK2CHAT_CHROME_PROFILE_DIR=~/Library/Application Support/Click2Chat/ChromeProfile
CLICK2CHAT_REMOTE_DEBUGGING_PORT=9222
CLICK2CHAT_DEBOUNCE_INTERVAL=1
CLICK2CHAT_HEALTH_CHECK_INTERVAL=10
CLICK2CHAT_WEB_LOAD_TIMEOUT=20
CLICK2CHAT_WEB_POLL_INTERVAL=0.5

